---
import type { ResolvedSite } from "../../types/client";

type Props = { site: ResolvedSite };
const { site } = Astro.props;
---

<section class="fc-section fc-section--tight" aria-labelledby="home-estimate">
  <div class="fc-shell">
    <div class="fc-card" style="padding: clamp(1.25rem, 3vw, 2rem); background: linear-gradient(135deg, #f3f7f2 0%, #fff 55%);">
      <h2 id="home-estimate" class="fc-h2">Get a clear estimate</h2>
      <p class="fc-lead" style="margin: 0 0 1rem; max-width: 60ch;">{site.niche.contactGoalLabel}</p>
      <div class="fc-btn-row">
        <a class="fc-btn fc-btn--primary" href={site.estimateCtaHref}>{site.estimateCtaLabel}</a>
        <a class="fc-btn fc-btn--secondary" href={site.secondaryCtaHref}>{site.secondaryCtaLabel}</a>
      </div>
    </div>
  </div>
</section>
