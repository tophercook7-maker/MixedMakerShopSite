# Public site URL (bookmarklet + quick-add copy; defaults to current origin in browser)
# NEXT_PUBLIC_SITE_URL=https://mixedmakershop.com

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for form submissions and creating leads from public forms (server-only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Scout-Brain integration (server-side admin integration)
SCOUT_BRAIN_API_BASE_URL=https://your-scout-brain-api.example.com
# Optional: POST /api/enrich-lead auth — must match Scout Brain SCOUT_ENRICH_API_KEY when set there
# SCOUT_ENRICH_API_KEY=
# Legacy alias for the same header:
# SCOUT_BRAIN_API_KEY=
# Optional explicit workspace scope for Scout requests
# SCOUT_BRAIN_WORKSPACE_ID=your-workspace-id

# 3D print labor bracket reference rate (default 40). Bracket amounts in UI are fixed USD; this is for display / future use.
# PRINT_LABOR_RATE_USD_PER_HOUR=40
# NEXT_PUBLIC_PRINT_LABOR_RATE_USD_PER_HOUR=40

# 3D print / CRM payments — Cash App (primary). Optional handle for copy (else URL is used in messages).
# NEXT_PUBLIC_CASHAPP_PAYMENT_URL=https://cash.app/$YourCashTag
# NEXT_PUBLIC_CASHAPP_HANDLE=$YourCashTag

# --- Stripe Checkout (3D print leads, optional) ---
# Server-only secrets — never expose to the client or NEXT_PUBLIC_*.
# STRIPE_SECRET_KEY=sk_test_...   # or sk_live_... in production
# STRIPE_WEBHOOK_SECRET=whsec_... # Dashboard → Webhooks → signing secret (or `stripe listen` output locally)
#
# Show Stripe buttons on admin 3D print lead detail (Payments sidebar). Cash App remains default.
# NEXT_PUBLIC_SHOW_STRIPE_PRINT_PAYMENTS=true
#
# Redirect URLs after Checkout (also used for other features). On Vercel, VERCEL_URL is a fallback.
# NEXT_PUBLIC_SITE_URL=https://your-domain.com
#
# Webhook fulfillment writes to Supabase with the service role (required for RLS bypass).
# SUPABASE_SERVICE_ROLE_KEY is listed above — required when using /api/stripe/webhook.
#
# Publishable key is optional for server-created Checkout Sessions (required for Stripe.js / Elements).
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Deep Well Audio: World Watch membership (Stripe Billing subscriptions) ---
# STRIPE_PRICE_ID_MONTHLY=price_...
# STRIPE_PRICE_ID_YEARLY=price_...   # optional second plan
#
# Signed cookie after Checkout (guest devices). Prefer a dedicated secret in production.
# MEMBER_SESSION_SECRET=long-random-string
# (Falls back to STRIPE_WEBHOOK_SECRET only if MEMBER_SESSION_SECRET is unset — not ideal for production.)
#
# Checkout redirect: success → /account/claim?session_id=... → sets cookie → /account/success
# Customer portal: POST /api/stripe/customer-portal
# Webhook: extend same endpoint; events include subscription lifecycle + checkout.session.completed (subscription mode)

# --- Deep Well Weekly (member email, Resend) ---
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL="Deep Well <hello@yourdomain.com>"
# Optional reply-to / failures visibility
# DEEP_WELL_WEEKLY_REPLY_TO=support@yourdomain.com
#
# Vercel cron: set DEEP_WELL_WEEKLY_AUTO=true (MANUAL_ONLY_MODE defaults true; cron also needs this or manual_trigger)
# Optional shared secret (or reuse CRON_SECRET): Vercel sends Authorization: Bearer <CRON_SECRET>
# DEEP_WELL_WEEKLY_CRON_SECRET=
#
# Local / off-schedule testing: bypass Sunday 7–9am Chicago window
# DEEP_WELL_WEEKLY_SKIP_TIME_GUARD=1
#
# Optional: refine AI draft (template still works without)
# OPENAI_API_KEY=
# OPENAI_WEEKLY_EMAIL_MODEL=gpt-4o-mini
